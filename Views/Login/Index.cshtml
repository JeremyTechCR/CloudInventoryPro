@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">

    <div class="col-md-4">

        <div class="card shadow">

            <div class="card-header bg-dark text-white text-center">
                <h3>CloudInventoryPro</h3>
            </div>

            <div class="card-body">

                <form asp-action="Index">

                    <div class="mb-3">

                        <label>Correo</label>

                        <input type="email"
                               name="correo"
                               class="form-control" />
                    </div>

                    <div class="mb-3">

                        <label>Contraseña</label>

                        <input type="password"
                               name="clave"
                               class="form-control" />
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        Iniciar Sesión
                    </button>

                </form>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mt-3">
                        @ViewBag.Error
                    </div>
                }

            </div>

        </div>

    </div>

</div>