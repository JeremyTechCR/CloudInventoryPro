@model IEnumerable<CloudInventoryPro.Models.Venta>

@{
    ViewData["Title"] = "Ventas";
}

<h1>Ventas</h1>

<p>
    <a asp-action="CrearVentaDetalle" class="btn btn-success">
        Nueva Venta
    </a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Fecha Venta</th>
            <th>Total</th>
            <th>Cliente</th>
            <th width="180">Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.FechaVenta.ToString("dd/MM/yyyy HH:mm")
                </td>

                <td>
                    ₡ @item.Total.ToString("N2")
                </td>

                <td>
                    @item.Cliente?.Nombre
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.IdVenta"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.IdVenta"
                       class="btn btn-info btn-sm">
                        Detalles
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.IdVenta"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>

                    <a asp-action="GenerarFactura"
                       asp-route-id="@item.IdVenta"
                       class="btn btn-success btn-sm">
                        PDF
                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>