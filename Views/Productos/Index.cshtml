@model IEnumerable<CloudInventoryPro.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1 class="mb-4">Lista de Productos</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Producto
</a>

<input type="text"
       id="buscarProducto"
       class="form-control mb-3"
       placeholder="Buscar producto por nombre, descripción o categoría..." />


<select id="filtroCategoria"
        class="form-select mb-3">

    <option value="">
        Todas las categorías
    </option>

    @foreach (var categoria in ViewBag.Categorias)
    {
        <option value="@categoria.Nombre">
            @categoria.Nombre
        </option>
    }

</select>

<table class="table table-bordered table-striped">

    <thead class="table-dark">

        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Imagen</th>
        </tr>

    </thead>

    <tbody id="tablaProductos">

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.IdProducto</td>

                <td>@item.Nombre</td>

                <td>₡ @item.Precio</td>

                <td>@item.Stock</td>

                <td>@item.Categoria?.Nombre</td>

                <td>

                    @if (!string.IsNullOrEmpty(item.Imagen))
                    {
                        <img src="@item.Imagen"
                             width="100"
                             height="100"
                             style="object-fit:cover;
                        border-radius:10px;" />
                    }

                </td>

            </tr>
        }

    </tbody>

</table>

@section Scripts {

    <script>

        function cargarProductos() {

            let termino =
                document.getElementById("buscarProducto").value;

            let categoria =
                document.getElementById("filtroCategoria").value;

            fetch(`/Productos/Buscar?termino=${termino}&categoria=${categoria}`)

                .then(response => response.json())

                .then(data => {

                    let filas = "";

                    data.forEach(p => {

                        let imagen = p.imagen
                            ? `<img src="${p.imagen}"
                                     width="80"
                                     height="80"
                                     style="object-fit:cover;
                                            border-radius:10px;" />`
                            : "";

                        filas += `
                            <tr>
                                <td>${p.idProducto}</td>
                                <td>${p.nombre}</td>
                                <td>₡ ${p.precio}</td>
                                <td>${p.stock}</td>
                                <td>${p.categoria}</td>
                                <td>${imagen}</td>
                            </tr>
                        `;
                    });

                    document.getElementById("tablaProductos")
                        .innerHTML = filas;
                });
        }

        document.getElementById("buscarProducto")
            .addEventListener("keyup", cargarProductos);

        document.getElementById("filtroCategoria")
            .addEventListener("change", cargarProductos);

    </script>

}